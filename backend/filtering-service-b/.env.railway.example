# Kafka (Confluent Cloud)
KAFKA_BOOTSTRAP_SERVERS='pkc-xxxxx.<region>.aws.confluent.cloud:9092'
KAFKA_GROUP_ID='filtering-service-b'
KAFKA_INPUT_TOPIC='sentrix.filter-service-a.cleaned'
KAFKA_FILTERED_TOPIC='sentrix.filter-service-b.filtered'
KAFKA_REJECTED_TOPIC='sentrix.filter-service-b.rejected'
KAFKA_CLIENT_ID='filtering-service-b'
KAFKA_AUTO_OFFSET_RESET='earliest'
KAFKA_ENABLE_AUTO_COMMIT=false
KAFKA_SECURITY_PROTOCOL='SASL_SSL'
KAFKA_SASL_MECHANISM='PLAIN'
KAFKA_SASL_USERNAME='<CONFLUENT_API_KEY>'
KAFKA_SASL_PASSWORD='<CONFLUENT_API_SECRET>'
KAFKA_SSL_CA_LOCATION=

APP_LOG_LEVEL='INFO'
APP_ROLLING_SUMMARY_EVERY=100
APP_NEAR_THRESHOLD_WINDOW=0.05

# Redis on Railway
REDIS_HOST='redis.railway.internal'
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME='default'
REDIS_PASSWORD='<REDIS_PASSWORD>'
REDIS_SSL=false

STATE_SIMILARITY_TTL_SECONDS=21600
STATE_AUTHOR_TICKER_TTL_SECONDS=43200
STATE_ACCEPTED_NOVELTY_TTL_SECONDS=86400
STATE_BURST_BUCKET_TTL_SECONDS=7200
STATE_MAX_LIST_ITEMS=200

RELEVANCE_MODEL_NAME=all-MiniLM-L6-v2
RELEVANCE_TICKER_PROFILES_PATH=/app/src/filtering_service_b/resources/tickers.json
RELEVANCE_STRONG_SIMILARITY_THRESHOLD=0.58
RELEVANCE_MEDIUM_SIMILARITY_THRESHOLD=0.45
RELEVANCE_LOW_SIMILARITY_THRESHOLD=0.30
RELEVANCE_STRONG_BOOST=0.02
RELEVANCE_MEDIUM_PENALTY=0.15
RELEVANCE_LOW_PENALTY=0.20
RELEVANCE_HARD_REJECT_EXTREME_LOW=false
RELEVANCE_EXTREME_LOW_PENALTY=0.20
RELEVANCE_REJECT_UNKNOWN_TICKER_PROFILE=true
RELEVANCE_NORMALIZE_EMBEDDINGS=true

MANIPULATION_CROSS_USER_ENABLED=true
MANIPULATION_CROSS_USER_MAX_HAMMING=5
MANIPULATION_CROSS_USER_MIN_MATCHES=2
MANIPULATION_CROSS_USER_MIN_UNIQUE_AUTHORS=2
MANIPULATION_CROSS_USER_PENALTY=0.20
MANIPULATION_CROSS_USER_STRONG_MATCHES=4
MANIPULATION_CROSS_USER_STRONG_PENALTY=0.35
MANIPULATION_CLUSTER_ENABLED=true
MANIPULATION_CLUSTER_MIN_MATCHES=3
MANIPULATION_CLUSTER_MIN_UNIQUE_AUTHORS=3
MANIPULATION_CLUSTER_MAX_TIME_SPAN_SECONDS=1800
MANIPULATION_CLUSTER_PENALTY=0.12
MANIPULATION_CLUSTER_STRONG_MATCHES=6
MANIPULATION_CLUSTER_STRONG_PENALTY=0.22
MANIPULATION_SAME_ACCOUNT_ENABLED=true
MANIPULATION_SAME_ACCOUNT_MAX_HAMMING=5
MANIPULATION_SAME_ACCOUNT_MIN_MATCHES=2
MANIPULATION_SAME_ACCOUNT_MAX_TIME_SPAN_SECONDS=1800
MANIPULATION_SAME_ACCOUNT_PENALTY=0.18
MANIPULATION_SAME_ACCOUNT_STRONG_MATCHES=4
MANIPULATION_SAME_ACCOUNT_STRONG_PENALTY=0.32
MANIPULATION_SAME_ACCOUNT_EXTREME_MATCHES=6
MANIPULATION_SAME_ACCOUNT_EXTREME_REJECT_ENABLED=false
MANIPULATION_BURST_ENABLED=true
MANIPULATION_BURST_RATIO_THRESHOLD=2.0
MANIPULATION_BURST_AMPLIFIER_SLOPE=0.25
MANIPULATION_BURST_MAX_MULTIPLIER=1.8

NOVELTY_ENABLED=true
NOVELTY_MAX_REFERENCES=20
NOVELTY_MEDIUM_SIMILARITY_THRESHOLD=0.82
NOVELTY_LOW_SIMILARITY_THRESHOLD=0.92
NOVELTY_MEDIUM_PENALTY=0.10
NOVELTY_LOW_PENALTY=0.20
NOVELTY_DISTINCT_SIMILARITY_THRESHOLD=0.45
NOVELTY_DISTINCT_BOOST=0.03
NOVELTY_MIN_REFERENCES_FOR_DISTINCT_BOOST=3

FINAL_KEEP_THRESHOLD=0.40
PORT=8080
HOST=0.0.0.0
